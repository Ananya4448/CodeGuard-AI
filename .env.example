# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MODEL_PROVIDER=openai  # openai, anthropic
MODEL_NAME=gpt-4-turbo-preview

# LangSmith (Optional - for tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=codereview-agent

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# Analysis Configuration
MAX_FILE_SIZE_MB=5
SUPPORTED_LANGUAGES=python,javascript,typescript,java,go
ENABLE_SECURITY_ANALYSIS=true
ENABLE_BUG_DETECTION=true
ENABLE_REFACTORING=true
ENABLE_QUALITY_SCORING=true

# Static Analysis Tools
PYLINT_ENABLED=true
FLAKE8_ENABLED=true
BANDIT_ENABLED=true
MYPY_ENABLED=true

# Evaluation Settings
EVALUATION_DATASET_PATH=./data/evaluation_dataset.json
CONFIDENCE_THRESHOLD=0.7
MIN_QUALITY_SCORE=60

# Performance
MAX_CONCURRENT_REVIEWS=10
AGENT_TIMEOUT_SECONDS=300
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# Database
DATABASE_URL=sqlite:///./codereview.db
# DATABASE_URL=postgresql://user:password@localhost/codereview

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/codereview.log

# Security
SECRET_KEY=your_secret_key_here_change_in_production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
